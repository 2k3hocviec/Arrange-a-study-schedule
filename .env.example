# App ports on your host machine
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Frontend API URL.
# Leave blank for local Docker/localhost. The frontend will call http://<current-host>:8000.
REACT_APP_API_URL=

# PostgreSQL exposed on your host.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=school1
POSTGRES_PORT=5432

# Used only inside Docker containers.
DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/school1?schema=public

# Used by local backend commands outside Docker.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/school1?schema=public

# Redis exposed on your host, plus the internal Docker hostname.
REDIS_HOST=localhost
REDIS_PORT=6379
DOCKER_REDIS_HOST=redis
DOCKER_REDIS_PORT=6379

# Seed database after Prisma db push during docker compose up.
# seed.ts clears and recreates seed data, so set false when you want to keep data.
RUN_DB_SEED=true

# Backend CORS
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000

# Auth
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com
MAIL_FROM_NAME=Schedule Course

# Gemini chatbot
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
