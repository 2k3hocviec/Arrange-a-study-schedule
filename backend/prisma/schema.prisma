generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  phone     String?
  address   String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  role      String

  student Student?
  teacher Teacher?

  @@map("user")
}

model Department {
  department_id String  @id
  name          String
  description   String?

  teachers       Teacher[]
  majors         Major[]

  @@map("department")
}

model Major {
  major_id      String  @id
  name          String
  department_id String
  description   String?

  department     Department     @relation(fields: [department_id], references: [department_id])
  studentClasses StudentClass[]
  subjects       Subject[]

  @@map("major")
}

model StudentClass {
  class_id String @id
  name     String
  cohort   String
  capacity Int?
  major_id String @default("DEFAULT")

  major    Major     @relation(fields: [major_id], references: [major_id])
  students Student[]

  @@map("student_class")
}

model Student {
  student_id String @id
  name       String
  user_id    Int    @unique
  class_id   String @default("DEFAULT")

  user        User         @relation(fields: [user_id], references: [id])
  class       StudentClass @relation(fields: [class_id], references: [class_id])
  enrollments Enrollment[]

  @@map("student")
}

model Teacher {
  teacher_id    String @id
  user_id       Int    @unique
  name          String
  degree        String
  expertise     String
  department_id String @default("DEFAULT")

  user          User                  @relation(fields: [user_id], references: [id])
  department    Department            @relation(fields: [department_id], references: [department_id])
  course        Course[]
  busySchedules TeacherBusySchedule[]

  @@map("teacher")
}

model TeacherBusySchedule {
  busy_id    String   @id @default(uuid())
  teacher_id String
  busy_date  DateTime @db.Date
  start_slot Int      @default(1)
  end_slot   Int      @default(10)
  reason     String?
  status     String   @default("pending")
  reviewedBy Int?
  reject_reason String?

  teacher Teacher @relation(fields: [teacher_id], references: [teacher_id])

  @@unique([teacher_id, busy_date, start_slot, end_slot])
  @@map("teacher_busy_schedule")
}

model Subject {
  subject_id            String  @id
  name                  String
  credits               Int
  major_id              String  @default("DEFAULT")
  allow_same_major      Boolean @default(false)
  allow_same_department Boolean @default(false)

  major  Major    @relation(fields: [major_id], references: [major_id])
  course Course[]

  @@map("subject")
}

model Semester {
  semester_id String   @id @default(uuid())
  name        String
  school_year String
  start_date  DateTime @db.Date
  end_date    DateTime @db.Date
  is_active   Boolean  @default(false)

  courses Course[]

  @@unique([name, school_year])
  @@map("semester")
}

model Course {
  course_id          String @id @default(uuid())
  course_code        String? @unique
  subject_id         String
  teacher_id         String
  semester_id        String
  capacity           Int?
  remaining_capacity Int?
  required_room_type String @default("Theory")

  subject     Subject      @relation(fields: [subject_id], references: [subject_id])
  teacher     Teacher      @relation(fields: [teacher_id], references: [teacher_id])
  semester    Semester     @relation(fields: [semester_id], references: [semester_id])
  schedule    Schedule[]
  enrollments Enrollment[]

  @@map("course")
}

model Enrollment {
  enrollment_id String   @id @default(uuid())
  student_id    String
  course_id     String
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  student Student @relation(fields: [student_id], references: [student_id])
  course  Course  @relation(fields: [course_id], references: [course_id])

  @@unique([student_id, course_id])
  @@map("enrollment")
}

model Classroom {
  classroom_id String @id
  capacity     Int
  type         String
  description  String
  status       String

  schedule Schedule[]

  @@map("classroom")
}

model Schedule {
  schedule_id  String    @id @default(uuid())
  course_id    String
  classroom_id String
  dayOfWeek    String
  start_slot   Int
  end_slot     Int
  start_date   DateTime? @db.Date
  end_date     DateTime? @db.Date

  course Course    @relation(fields: [course_id], references: [course_id])
  room   Classroom @relation(fields: [classroom_id], references: [classroom_id])

  @@map("schedule")
}
