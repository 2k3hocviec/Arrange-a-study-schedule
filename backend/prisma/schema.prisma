generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  phone     String?
  address   String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  role      String

  student Student?
  teacher Teacher?

  @@map("user")
}

model Student {
  student_id String @id
  name       String
  user_id    Int    @unique

  user        User         @relation(fields: [user_id], references: [id])
  enrollments Enrollment[]

  @@map("student")
}

model Teacher {
  teacher_id String @id
  user_id    Int    @unique
  name       String
  degree     String
  expertise  String

  user   User     @relation(fields: [user_id], references: [id])
  course Course[]

  @@map("teacher")
}

model Subject {
  subject_id String @id
  name       String
  credits    Int

  course Course[]

  @@map("subject")
}

model Course {
  course_id          String @id @default(uuid())
  subject_id         String
  teacher_id         String
  capacity           Int?
  remaining_capacity Int?

  subject     Subject      @relation(fields: [subject_id], references: [subject_id])
  teacher     Teacher      @relation(fields: [teacher_id], references: [teacher_id])
  schedule    Schedule[]
  enrollments Enrollment[]

  @@map("course")
}

model Enrollment {
  enrollment_id String   @id @default(uuid())
  student_id    String
  course_id     String
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  student Student @relation(fields: [student_id], references: [student_id])
  course  Course  @relation(fields: [course_id], references: [course_id])

  @@unique([student_id, course_id])
  @@map("enrollment")
}

model Classroom {
  classroom_id String @id
  capacity     Int
  type         String
  description  String
  status       String

  schedule Schedule[]

  @@map("classroom")
}

model Schedule {
  schedule_id  String    @id @default(uuid())
  course_id    String
  classroom_id String
  dayOfWeek    String
  start_slot   Int
  end_slot     Int
  start_date   DateTime? @db.Date
  end_date     DateTime? @db.Date

  course Course    @relation(fields: [course_id], references: [course_id])
  room   Classroom @relation(fields: [classroom_id], references: [classroom_id])

  @@map("schedule")
}
